{
  "name": "eventsleuth",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:app": "vitest run src/__tests__/App.test.tsx",
    "test:search": "vitest run src/__tests__/SearchForm.test.tsx",
    "test:events": "vitest run src/__tests__/EventList.test.tsx",
    "test:all": "npm test && cd src-tauri && cargo test && cd ..",
    "test:backend": "cd src-tauri && cargo test && cd ..",
    "test:backend:verbose": "cd src-tauri && cargo test -- --nocapture && cd .."
  },
  "dependencies": {
    "@tanstack/react-query": "^5.24.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.0.1",
    "@tauri-apps/plugin-fs": "^2.0.2",
    "@tauri-apps/plugin-notification": "^2.2.0",
    "@tauri-apps/plugin-shell": "^2",
    "daisyui": "^4.7.2",
    "date-fns": "^3.3.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.1",
    "zustand": "^4.5.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.11",
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.0.15",
    "autoprefixer": "^10.4.17",
    "jsdom": "^23.0.0",
    "postcss": "^8.4.35",
    "typescript": "^5.2.2",
    "vite": "^7.2.6",
    "vitest": "^4.0.15"
  }
}
